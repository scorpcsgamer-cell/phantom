# ═══════════════════════════════════════════════════════
# PHANTOM v1.0 — Configuration (Phase 1: Fib + Div strategy)
# ═══════════════════════════════════════════════════════

# ── OKX API ────────────────────────────────────────────
# Создание ключа: https://www.okx.com/account/my-api
# 1. Profile → API → Create V5 API Key
# 2. Permissions: ☑ Read + ☑ Trade (БЕЗ Withdraw!)
# 3. Passphrase придумываете сами при создании
OKX_API_KEY=
OKX_API_SECRET=
OKX_PASSPHRASE=
OKX_TESTNET=true

# ── Risk Management ────────────────────────────────────
RISK_PER_TRADE=1.0
MAX_DAILY_LOSS=5.0
MAX_DRAWDOWN_STOP=15.0
LEVERAGE=5
MAX_POSITIONS=5
SL_PCT=1.5
TP_PCT=3.0
TRAIL_PCT=0.8
COOLDOWN_AFTER_SL=60

# ── Signals ────────────────────────────────────────────
SIGNAL_CONFIDENCE=82.0
STRATEGY=auto
AUTO_STRATEGY_REASSESS_S=300
WARMUP_SCANS=3
SIGNAL_CONFIRM_TICKS=2

# ── Scanner ────────────────────────────────────────────
SCAN_INTERVAL=30
MIN_VOLUME_USDT=3000000
MIN_ATR_PCT=1.0

# ── Persistence ────────────────────────────────────────
AUTO_RESTORE=true
PERSIST_INTERVAL_S=30
RECONCILE_INTERVAL_S=300

# ── Network Safety ─────────────────────────────────────
PANIC_CLOSE_AFTER_S=600

# ── Funding & Slippage ─────────────────────────────────
AVOID_FUNDING_MIN=5
SLIPPAGE_PCT=0.05

# ── WebSocket ──────────────────────────────────────────
USE_WEBSOCKET=true

# ── Position Mode ──────────────────────────────────────
# ВАЖНО: AUTO_SWITCH_POSITION_MODE объявлен один раз (раньше был дубликат)
REQUIRE_ONE_WAY_MODE=true
AUTO_SWITCH_POSITION_MODE=true

# ── Liquidation Monitor ────────────────────────────────
LIQ_CRITICAL_PCT=5.0
LIQ_EMERGENCY_PCT=15.0
LIQ_CHECK_INTERVAL_S=60
AUTO_RESTORE_SL_TP=true

# ── Order Health ───────────────────────────────────────
ORDER_HEALTH_THRESHOLD=5
ORDER_HEALTH_WINDOW_S=60
ORDER_HEALTH_PAUSE_S=300

# ── Telegram Alerts ────────────────────────────────────
# Создайте бота через @BotFather, получите токен
# Свой chat_id узнайте через @userinfobot
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_ENABLED=true
DAILY_SUMMARY_HOUR_UTC=0

# ── Partial Take-Profit ────────────────────────────────
ENABLE_PARTIAL_TP=false
TP_LEVELS=3:50,6:30,10:20
MOVE_SL_TO_BE_AFTER_TP1=true
TRAIL_AFTER_LAST_TP=true
TRAIL_PCT_AFTER_ALL_TP=1.5

# ── Volume Anomaly Modules (v1.1) ──────────────────────
# 1) Z-score детектор аномалий объёма (блокирует вход в позицию)
#    spike (z>+3): возможен pump-and-dump → не лезем за движением
#    drop  (z<-2): пересохшая ликвидность → ордера будут с проскальзыванием
VOLUME_ANOMALY_ENABLED=true
VOLUME_Z_WINDOW=50
VOLUME_Z_THRESHOLD=3.0

# 2) Drop Guard для открытых позиций
#    Если средний объём за 1ч упал в N раз ниже среднего за 4ч —
#    подтягиваем SL на VOLUME_DROP_TIGHTEN_PCT % к рынку.
#    VOLUME_DROP_ACTION: alert | tighten_sl | close
#    Если будет срабатывать слишком часто — увеличить VOLUME_DROP_FACTOR до 4.0-5.0.
VOLUME_DROP_GUARD_ENABLED=true
VOLUME_DROP_FACTOR=3.0
VOLUME_DROP_ACTION=tighten_sl
VOLUME_DROP_TIGHTEN_PCT=1.0

# 3) Price/Volume Divergence — 17-й индикатор для голосования
#    Цена↑ + объём↓ → bear (выдыхающееся ралли)
#    Цена↓ + объём↓ → bull (продавцы выдыхаются)
VOLUME_DIVERGENCE_ENABLED=true
VOLUME_DIV_LOOKBACK=10

# ═══════════════════════════════════════════════════════
# ── PHASE 1: Fib + Divergence Strategy (NEW) ───────────
# ═══════════════════════════════════════════════════════
# Главный переключатель новой стратегии.
# true  = multi-TF тренд + Fib retracement + RSI/MACD дивергенция
# false = старая логика "топ движущихся" (fallback)
# При проблемах можно мгновенно откатиться поставив false и перезапустив.
USE_FIB_STRATEGY=true

# ── Trend filter (multi-TF: 4h + 1h) ───────────────────
# Минимальный наклон EMA за бар. Калибровка #2 на основе лога от 22 мая:
# при 0.001 (0.1%/бар) 99% времени все 33 символа в "flat". При 0.0005
# (0.05%/бар) символы с слабым трендом начнут проходить как "up/down".
# Это ещё не "мягко" — порог 0.05% за бар реалистичен для крипты.
TREND_SLOPE_THRESHOLD=0.0005
# Кеш на 5 минут — экономит запросы (4h тренд не меняется быстрее)
TREND_CACHE_TTL_S=300

# ── Fib engine ─────────────────────────────────────────
# Допуск "цена на уровне" в %. Калибровка #2 на основе лога от 22 мая:
# 4.5 часа боковика, 0 сделок. JUP/ICP постоянно ходят в 1.0-1.8% от
# Fib уровней — попадают в коридор, но не дотягивают до 1.0%. Расширяем
# до 2.0% — это позволит ловить эти моменты. Старая стратегия (NEAR @
# 0.5 уровень, успешный +$14.30) попала бы в этот коридор тоже.
FIB_TOLERANCE_PCT=2.0
# Минимум амплитуды свинга в ATR. 1.5 отсекает микро-свинги.
FIB_SWING_ATR_MULT=1.5

# ── Divergence ─────────────────────────────────────────
# Окно поиска экстремумов RSI/MACD. 30 = последние 30 баров на entry TF.
DIV_LOOKBACK=30

# ── Adaptive Timeframe ─────────────────────────────────
# true: бот сам выбирает 1m/5m/15m/1h по ATR% и BB Width
# false: используется фиксированный FALLBACK_TF
USE_ADAPTIVE_TF=true
FALLBACK_TF=15m

# ── Meme Strategy (PEPE, FLOKI, BONK, SHIB, DOGE, ...) ─
# На мемах Fib работает плохо, используется volume spike + RSI extreme.
MEME_STRATEGY_ENABLED=true
MEME_RISK_PCT=0.75
MEME_SL_PCT=1.0
MEME_TP_PCT=2.0
MEME_MAX_CONCURRENT=1

# ── Correlation Guard ──────────────────────────────────
# Max позиций в одну сторону (long или short). Защита от того что
# при падении BTC все альты падают синхронно и все long в минусе.
CORR_MAX_SAME_DIRECTION=2
# Суммарный риск всех открытых позиций ≤ N% портфеля.
# При SL_PCT=1.5 это позволит 3 полных позиции (3 × 1.5% = 4.5%).
CORR_MAX_PORTFOLIO_RISK=4.5

# ── Circuit Breaker ────────────────────────────────────
# При N убыточных закрытий подряд бот ставится на паузу на M часов.
SL_STREAK_THRESHOLD=3
SL_STREAK_PAUSE_HOURS=4
